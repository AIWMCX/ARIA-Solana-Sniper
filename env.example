# ─────────────────────────────────────────────────────────────────────────────
# ARIA Telegram Terminal — Environment
# Copy this to .env (local) or set in Railway/Fly (prod).
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram (send /newbot, follow prompts).
TELEGRAM_BOT_TOKEN=

# Your Telegram username WITHOUT the @ (e.g. "yourname"). Used so the bot can
# DM you about new leads as a fallback to email.
ADMIN_TELEGRAM_USERNAME=

# Your numeric Telegram user ID. Easiest way: DM @userinfobot. Optional but
# recommended — lets the bot push you DM alerts about new leads.
ADMIN_TELEGRAM_CHAT_ID=

# The public HTTPS URL where this app is hosted (Railway/Fly/your domain).
# MUST be HTTPS — Telegram refuses plain http for Mini Apps.
# Example: https://aria-terminal.up.railway.app
# Local dev: use `ngrok http 8080` and paste the https URL here.
PUBLIC_URL=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up free at https://resend.com (3,000 emails/mo free, no card).
# Create an API key under "API Keys" → paste here.
RESEND_API_KEY=

# Where lead emails get delivered. Use the address you actually check.
ADMIN_EMAIL=

# The "from" address. For instant testing use Resend's sandbox:
#   FROM_EMAIL=onboarding@resend.dev
# For production, verify your own domain in Resend and use e.g.
#   FROM_EMAIL=leads@yourdomain.com
FROM_EMAIL=onboarding@resend.dev

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info

# SQLite file path (auto-created on first run). On Railway, mount a volume at
# /data and set this to /data/leads.db so leads survive deploys.
DB_PATH=./data/leads.db
